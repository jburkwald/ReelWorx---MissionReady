{
  "name": "reelworx-nextmission",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.11.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --filter=@reelworx/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "npm run generate --workspace=packages/shared",
    "db:push": "npm run push --workspace=packages/shared",
    "db:seed": "npm run seed --workspace=packages/shared",
    "db:studio": "npm run studio --workspace=packages/shared"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "~6.0.3",
    "prettier": "^3.3.0"
  },
  "//react": "Declared at the root + pinned via overrides so the whole monorepo shares ONE hoisted React (Expo SDK 56's expected 19.2.3). Without this, Next and @clerk/clerk-react can't resolve react/react-dom.",
  "dependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "engines": {
    "node": ">=20"
  }
}
