# This monorepo runs the absolute-latest majors (React 19, RN 0.86, Expo 56,
# Next 16, Clerk 7). Some peer-dependency ranges in the ecosystem trail those
# versions slightly, so npm's strict peer resolution would reject otherwise-valid
# trees. legacy-peer-deps installs the intended versions and downgrades peer
# mismatches to warnings. Revisit (and ideally remove) as the ecosystem catches up.
legacy-peer-deps=true
