{
  "expo": {
    "name": "ReelWorx MissionReady",
    "slug": "reelworx-nextmission",
    "scheme": "reelworx",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reelworx.nextmission"
    },
    "android": {
      "package": "com.reelworx.nextmission",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "ReelWorx uses your library so you can choose a short intro video.",
          "cameraPermission": "ReelWorx uses the camera so you can record your intro video.",
          "microphonePermission": "ReelWorx uses the microphone so your intro video has sound."
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
