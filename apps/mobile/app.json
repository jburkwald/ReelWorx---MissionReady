{
  "expo": {
    "name": "ReelWorx NextMission",
    "slug": "reelworx-nextmission",
    "scheme": "reelworx",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reelworx.nextmission"
    },
    "android": {
      "package": "com.reelworx.nextmission",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
